DATABASE_URL=postgres://postgres:ADMIN_PASSWORD@postgres:5432/registry?sslmode=disable
REGISTRY_URL=http://registry:7272
BACKUP_TOKEN=<shared-with-registry>
BACKUP_S3_BUCKET=not-so-localhost-backups
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<iam-access-key>
AWS_SECRET_ACCESS_KEY=<iam-secret-key>
KEYCLOAK_DB_PASSWORD=<from-postgres-env>
REGISTRY_DB_PASSWORD=<from-postgres-env>
POSTGRES_ADMIN_PASSWORD=admin
BACKUP_INTERVAL=1h
STALE_BACKUP_DAYS=30
BACKUP_DIR=/backups
